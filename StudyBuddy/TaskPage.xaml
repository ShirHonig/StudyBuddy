<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudyBuddy.TasksPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#f7fafd">

    <Grid RowDefinitions="64,*,76">

        <!-- ── Top App Bar ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" BackgroundColor="#f7fafd" Padding="16,0"
              ColumnDefinitions="Auto,*,Auto">
            <Frame Grid.Column="0" WidthRequest="34" HeightRequest="34" CornerRadius="17"
                   BackgroundColor="#96a5ff" Padding="0" BorderColor="Transparent"
                   IsClippedToBounds="True" VerticalOptions="Center">
                <Label Text="א" TextColor="#27378a" FontAttributes="Bold" FontSize="14"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Frame>
            <Label Grid.Column="1" Text="StudyBuddy"
                   FontSize="20" FontAttributes="Bold" TextColor="#0040a1"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <Label Grid.Column="2" Text="🔔" FontSize="20"
                   VerticalOptions="Center" HorizontalOptions="End"/>
        </Grid>

        <!-- ── Scrollable Body ───────────────────────────────────────────────── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="16,20,16,8">

                <!-- Hero Header -->
                <VerticalStackLayout Spacing="6" Margin="0,-8,0,20" HorizontalOptions="Center">
                    <Label Text="המשימות שלי"
                           FontSize="34" FontAttributes="Bold" TextColor="#0040a1"
                           HorizontalOptions="Center" CharacterSpacing="-0.5">
                        <Label.Shadow>
                            <Shadow Brush="#0040a1" Offset="0,3" Radius="12" Opacity="0.18"/>
                        </Label.Shadow>
                    </Label>
                    <Label x:Name="DateLabel" FontSize="13" TextColor="#737785"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Add Task Button -->
                <Button Text="＋  הוספת משימה חדשה"
                        BackgroundColor="#0040a1" TextColor="White"
                        CornerRadius="14" HeightRequest="52"
                        FontSize="16" FontAttributes="Bold"
                        Margin="0,0,0,24"
                        Clicked="OnAddTaskClicked"/>

                <!-- Search box -->
                <Frame BackgroundColor="White" CornerRadius="14" Padding="4,0"
                       BorderColor="#e5e8eb" Margin="0,0,0,16" HasShadow="False">
                    <SearchBar x:Name="SearchEntry"
                               Placeholder="חפש משימה..."
                               FlowDirection="RightToLeft"
                               BackgroundColor="Transparent"
                               TextChanged="OnSearchTextChanged"/>
                </Frame>

                <!-- ── Stats Row ── -->
                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                            Margin="0,0,0,20">
                    <HorizontalStackLayout Spacing="10">
                        <Frame x:Name="StatTotalFrame"
                               BackgroundColor="#0040a1" CornerRadius="14"
                               WidthRequest="110" HeightRequest="76"
                               Padding="12" BorderColor="White" HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatTotalTapped"/>
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="סה״כ" FontSize="12" TextColor="#b2c5ff"/>
                                <Label x:Name="TotalCountLabel" Text="0"
                                       FontSize="26" FontAttributes="Bold" TextColor="White"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame x:Name="StatInProgressFrame"
                               BackgroundColor="#2563eb" CornerRadius="14"
                               WidthRequest="110" HeightRequest="76"
                               Padding="12" BorderColor="Transparent" HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatInProgressTapped"/>
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="בתהליך" FontSize="12" TextColor="#bfdbfe"/>
                                <Label x:Name="InProgressCountLabel" Text="0"
                                       FontSize="26" FontAttributes="Bold" TextColor="White"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame x:Name="StatCompletedFrame"
                               BackgroundColor="#16a34a" CornerRadius="14"
                               WidthRequest="110" HeightRequest="76"
                               Padding="12" BorderColor="Transparent" HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatCompletedTapped"/>
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="הושלם" FontSize="12" TextColor="#bbf7d0"/>
                                <Label x:Name="CompletedCountLabel" Text="0"
                                       FontSize="26" FontAttributes="Bold" TextColor="White"/>
                            </VerticalStackLayout>
                        </Frame>

                        <Frame x:Name="StatUrgentFrame"
                               BackgroundColor="#dc2626" CornerRadius="14"
                               WidthRequest="110" HeightRequest="76"
                               Padding="12" BorderColor="Transparent" HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnStatUrgentTapped"/>
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="דחוף" FontSize="12" TextColor="#fecaca"/>
                                <Label x:Name="UrgentCountLabel" Text="0"
                                       FontSize="26" FontAttributes="Bold" TextColor="White"/>
                            </VerticalStackLayout>
                        </Frame>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- ── Filter Chips ── -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            FlowDirection="RightToLeft"
                            Margin="0,0,0,20">
                    <HorizontalStackLayout x:Name="ChipsContainer" Spacing="8" Padding="0,2"
                                           FlowDirection="RightToLeft">
                        <Button x:Name="TabAllButton" Text="הכל"
                                BackgroundColor="#0040a1" TextColor="White"
                                CornerRadius="20" HeightRequest="36" Padding="16,0"
                                FontSize="13" FontAttributes="Bold"
                                Clicked="OnTabAllClicked"/>
                        <Button x:Name="TabTodayButton" Text="היום"
                                BackgroundColor="#e5e8eb" TextColor="#424654"
                                CornerRadius="20" HeightRequest="36" Padding="16,0"
                                FontSize="13" Clicked="OnTabTodayClicked"/>
                        <Button x:Name="TabWeekButton" Text="השבוע"
                                BackgroundColor="#e5e8eb" TextColor="#424654"
                                CornerRadius="20" HeightRequest="36" Padding="16,0"
                                FontSize="13" Clicked="OnTabWeekClicked"/>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- ── Task List ── -->
                <CollectionView x:Name="TasksListView" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItem Text="עריכה"
                                                   BackgroundColor="#0040a1"
                                                   Invoked="OnSwipeEditInvoked"
                                                   CommandParameter="{Binding .}"/>
                                        <SwipeItem Text="מחיקה"
                                                   BackgroundColor="#dc2626"
                                                   IsDestructive="True"
                                                   Invoked="OnSwipeDeleteInvoked"
                                                   CommandParameter="{Binding .}"/>
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <Frame BackgroundColor="White" CornerRadius="18" Padding="0"
                                       BorderColor="Transparent" IsClippedToBounds="True"
                                       HasShadow="True">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTaskCardTapped"
                                                              CommandParameter="{Binding .}"/>
                                    </Frame.GestureRecognizers>
                                    <Grid ColumnDefinitions="6,*,Auto">
                                        <!-- Priority color bar -->
                                        <BoxView Grid.Column="0"
                                                 Color="{Binding PriorityColor}"
                                                 VerticalOptions="Fill"/>
                                        <!-- Content -->
                                        <VerticalStackLayout Grid.Column="1" Padding="16,14" Spacing="6">
                                            <Label Text="{Binding Title}" FontSize="16"
                                                   FontAttributes="Bold" TextColor="#181c1e"
                                                   HorizontalOptions="End" HorizontalTextAlignment="End"/>
                                            <Label Text="{Binding Description}" FontSize="13"
                                                   TextColor="#424654" LineBreakMode="TailTruncation"
                                                   MaxLines="1"
                                                   HorizontalOptions="End" HorizontalTextAlignment="End"/>
                                            <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                                <Frame BackgroundColor="{Binding CategoryColor}"
                                                       CornerRadius="8" Padding="8,3"
                                                       BorderColor="Transparent" HasShadow="False">
                                                    <Label Text="{Binding Category}" FontSize="11"
                                                           TextColor="White" FontAttributes="Bold"/>
                                                </Frame>
                                                <Frame BackgroundColor="{Binding PriorityBackgroundColor}"
                                                       CornerRadius="8" Padding="8,3"
                                                       BorderColor="{Binding PriorityColor}"
                                                       HasShadow="False">
                                                    <Label Text="{Binding Priority}" FontSize="11"
                                                           TextColor="{Binding PriorityColor}"
                                                           FontAttributes="Bold"/>
                                                </Frame>
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="14" HorizontalOptions="End"
                                                                   Margin="0,4,0,0">
                                                <Label Text="{Binding Date}" FontSize="12"
                                                       TextColor="#0040a1" FontAttributes="Bold"/>
                                                <Label Text="{Binding TeacherName}" FontSize="12"
                                                       TextColor="#737785"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                        <!-- Checkbox -->
                                        <CheckBox Grid.Column="2" IsChecked="{Binding IsCompleted}"
                                                  Color="#0040a1"
                                                  CheckedChanged="OnCheckBoxChanged"
                                                  VerticalOptions="Center"
                                                  Margin="0,0,10,0"/>
                                    </Grid>
                                </Frame>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Bottom Navigation Bar ─────────────────────────────────────────── -->
        <Grid Grid.Row="2" BackgroundColor="#f7fafd"
              ColumnDefinitions="*,*,*,*" Padding="0,8,0,0">
            <!-- Home -->
            <VerticalStackLayout Grid.Column="0" Spacing="2"
                                 HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="🏠" FontSize="22" HorizontalOptions="Center"/>
                <Label Text="דף הבית" FontSize="10" TextColor="#424654"
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeNavTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <!-- Tasks (active) -->
            <Frame Grid.Column="1" BackgroundColor="#dae2ff" CornerRadius="16"
                   Padding="0,6" BorderColor="Transparent" Margin="4,4">
                <VerticalStackLayout Spacing="2"
                                     HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="✅" FontSize="22" HorizontalOptions="Center"/>
                    <Label Text="משימות" FontSize="10" TextColor="#0040a1"
                           FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
            <!-- Groups -->
            <VerticalStackLayout Grid.Column="2" Spacing="2"
                                 HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="👥" FontSize="22" HorizontalOptions="Center"/>
                <Label Text="קבוצות" FontSize="10" TextColor="#424654"
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGroupsNavTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
            <!-- Calendar -->
            <VerticalStackLayout Grid.Column="3" Spacing="2"
                                 HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="📅" FontSize="22" HorizontalOptions="Center"/>
                <Label Text="לוח שנה" FontSize="10" TextColor="#424654"
                       HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCalendarNavTapped"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
